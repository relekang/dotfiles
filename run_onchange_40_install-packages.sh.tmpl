{{ if has "packages" ((index .chezmoi "tags") | default (list)) }}#!/usr/bin/env bash
set -euo pipefail

case "{{ .chezmoi.os }}" in
  darwin)
    if ! command -v brew >/dev/null 2>&1; then
      /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
      if [[ -x /opt/homebrew/bin/brew ]]; then
        eval "$(/opt/homebrew/bin/brew shellenv)"
      elif [[ -x /usr/local/bin/brew ]]; then
        eval "$(/usr/local/bin/brew shellenv)"
      fi
    fi

    brew install \
      ansible \
      coreutils \
      fnm \
      gh \
      git-flow \
      git-lfs \
      glow \
      gnu-sed \
      grip \
      htop \
      httpie \
      jq \
      mosh \
      nginx \
      node \
      openjdk \
      poppler \
      postgresql \
      redis \
      ripgrep \
      sops \
      sshuttle \
      watch \
      wget \
      yippy \
      uv

    brew install --cask \
      alfred \
      docker \
      dropbox \
      firefox \
      google-cloud-sdk \
      jetbrains-toolbox \
      keycastr \
      nightfall \
      postico \
      postgres-unofficial \
      spotify
    ;;
  linux)
    if command -v apt-get >/dev/null 2>&1; then
      sudo apt-get update
      sudo apt-get install -y jq ripgrep wget
    fi
    ;;
esac
{{ end }}