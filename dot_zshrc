export XDG_CONFIG_HOME="${XDG_CONFIG_HOME:-$HOME/.config}"
export ZSH="$HOME/.oh-my-zsh"
export ZSH_CUSTOM="$XDG_CONFIG_HOME/zsh/oh-my-zsh-custom"
export ZSH_THEME="rl"
export CASE_SENSITIVE="true"
export HIST_STAMPS="yyyy-mm-dd"
export STARSHIP_CONFIG="$XDG_CONFIG_HOME/starship.toml"
export PROJECTS="$HOME/dev"
export EDITOR="nvim"
export LC_ALL="en_US.UTF-8"
export LANG="en_US.UTF-8"
export GOPATH="$HOME/.gocode"
export NVIM_APPNAME="lazyvim"

if [[ -x /usr/libexec/java_home ]]; then
  export JAVA_HOME="$(/usr/libexec/java_home -v 1.8 2>/dev/null)"
fi

plugins=()

if [[ -f "$ZSH/oh-my-zsh.sh" ]]; then
  source "$ZSH/oh-my-zsh.sh"
fi

path=(
  /opt/homebrew/bin
  /usr/local/bin
  /usr/bin
  /bin
  /usr/sbin
  /sbin
  "$HOME/.local/bin"
  "$HOME/bin"
  "$HOME/.bin"
  "$HOME/.poetry/bin"
  "$HOME/.node-bin/node_modules/.bin"
  "$GOPATH/bin"
  $path
)
export PATH

if [[ -f "$HOME/.cargo/env" ]]; then
  source "$HOME/.cargo/env"
fi

if command -v mise >/dev/null 2>&1; then
  eval "$(mise activate -s zsh)"
fi

if command -v color-mode >/dev/null 2>&1; then
  export COLOR_MODE="$(color-mode)"
fi

if command -v python3 >/dev/null 2>&1; then
  export VIRTUALENVWRAPPER_PYTHON="$(command -v python3)"
fi

source "$XDG_CONFIG_HOME/zsh/aliases"
source "$XDG_CONFIG_HOME/zsh/chruby"
source "$XDG_CONFIG_HOME/zsh/functions"
source "$XDG_CONFIG_HOME/zsh/private-aliases.zsh"

if command -v brew >/dev/null 2>&1; then
  eval "$(brew shellenv)"
fi

if command -v fnm >/dev/null 2>&1; then
  eval "$(fnm env --use-on-cd --version-file-strategy=recursive)"
fi

if [[ -f "$HOME/.rye/env" ]]; then
  source "$HOME/.rye/env"
fi

for syntax_highlighting in \
  /opt/homebrew/share/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh \
  /usr/local/share/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh \
  /usr/share/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh
 do
  if [[ -f "$syntax_highlighting" ]]; then
    source "$syntax_highlighting"
    break
  fi
done

export FZF_DEFAULT_OPTS=" \
--color=bg+:#313244,bg:#1e1e2e,spinner:#f5e0dc,hl:#f38ba8 \
--color=fg:#cdd6f4,header:#f38ba8,info:#cba6f7,pointer:#f5e0dc \
--color=marker:#f5e0dc,fg+:#cdd6f4,prompt:#cba6f7,hl+:#f38ba8"

if command -v brew >/dev/null 2>&1; then
  local_google_cloud_sdk="$(brew --prefix)/share/google-cloud-sdk"
  if [[ -f "$local_google_cloud_sdk/path.zsh.inc" ]]; then
    source "$local_google_cloud_sdk/path.zsh.inc"
    source "$local_google_cloud_sdk/completion.zsh.inc"
    export USE_GKE_GCLOUD_AUTH_PLUGIN="True"
  fi

  FPATH="$(brew --prefix)/share/zsh-completions:$FPATH"
fi

if [[ -z "${SSH_AUTH_SOCK:-}" ]]; then
  eval "$(ssh-agent -s)" >/dev/null
fi

autoload -Uz compinit
compinit

export CLOUDSDK_PYTHON="/opt/homebrew/bin/python3.9"

if command -v starship >/dev/null 2>&1; then
  eval "$(starship init zsh)"
fi

if command -v zoxide >/dev/null 2>&1; then
  eval "$(zoxide init zsh)"
fi

[[ -f ~/.config/tabtab/zsh/__tabtab.zsh ]] && source ~/.config/tabtab/zsh/__tabtab.zsh || true
