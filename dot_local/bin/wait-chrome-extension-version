#!/usr/bin/env python3
"""Wait until a Chrome Web Store extension reaches a target version.

Quite useful for wait-chrome-extension-version <url> <version> && say "Extension is published!"
"""

from __future__ import annotations

import argparse
import re
import sys
import time
import urllib.error
import urllib.parse
import urllib.request
from datetime import datetime

INTERVAL_SECONDS = 120
UPDATE_URL = "https://clients2.google.com/service/update2/crx"
EXTENSION_ID_RE = re.compile(r"[a-p]{32}")
VERSION_RE = re.compile(r"^\d+(?:\.\d+){0,3}$")


def parse_extension_id(url_or_id: str) -> str:
    match = EXTENSION_ID_RE.search(url_or_id.lower())
    if not match:
        raise ValueError("could not find a Chrome extension id in the URL")
    return match.group(0)


def parse_version(version: str) -> tuple[int, ...]:
    if not VERSION_RE.match(version):
        raise ValueError("version must be 1 to 4 dot-separated numbers, e.g. 1.57.0")

    parts = [int(part) for part in version.split(".")]
    return tuple(parts + [0] * (4 - len(parts)))


def fetch_current_version(extension_id: str) -> str:
    query = urllib.parse.urlencode(
        {
            "response": "updatecheck",
            "prodversion": "120.0",
            "acceptformat": "crx2,crx3",
            "x": f"id={extension_id}&uc",
        }
    )
    request = urllib.request.Request(
        f"{UPDATE_URL}?{query}",
        headers={"User-Agent": "Mozilla/5.0"},
    )

    with urllib.request.urlopen(request, timeout=30) as response:
        body = response.read()

    text = body.decode("utf-8", errors="replace")
    updatecheck = re.search(r"<updatecheck\b[^>]*>", text)
    if not updatecheck:
        raise RuntimeError("could not find updatecheck in Chrome Web Store response")

    tag = updatecheck.group(0)
    status = re.search(r'\bstatus="([^"]+)"', tag)
    if not status:
        raise RuntimeError(
            "could not find updatecheck status in Chrome Web Store response"
        )
    if status.group(1) != "ok":
        raise RuntimeError(
            f"Chrome Web Store updatecheck status was {status.group(1)!r}"
        )

    version = re.search(r'\bversion="([^"]+)"', tag)
    if not version:
        raise RuntimeError("could not find version in Chrome Web Store response")

    return version.group(1)


def log(message: str) -> None:
    timestamp = datetime.now().strftime("%Y-%m-%d %H:%M:%S")
    print(f"[{timestamp}] {message}", flush=True)


def main() -> int:
    parser = argparse.ArgumentParser(
        description="Check a Chrome Web Store extension every 2 minutes until it reaches a target version."
    )
    parser.add_argument(
        "url", help="Chrome Web Store extension URL, or the extension id"
    )
    parser.add_argument("version", help="Target version, e.g. 1.57.0")
    args = parser.parse_args()

    try:
        extension_id = parse_extension_id(args.url)
        target_version = parse_version(args.version)
    except ValueError as error:
        print(f"Error: {error}", file=sys.stderr)
        return 2

    log(f"Waiting for {extension_id} to reach version {args.version} or higher")

    while True:
        try:
            current_version = fetch_current_version(extension_id)
            log(f"Current version: {current_version}")

            if parse_version(current_version) >= target_version:
                log(f"Done: {current_version} is >= {args.version}")
                return 0
        except (RuntimeError, urllib.error.URLError, TimeoutError) as error:
            log(f"Error checking version: {error}")

        time.sleep(INTERVAL_SECONDS)


if __name__ == "__main__":
    raise SystemExit(main())
