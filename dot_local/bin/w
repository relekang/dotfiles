#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<'EOF'
Usage:
  w c <project> [--no-tmux] <workspace-name>
  w create <project> [--no-tmux] <workspace-name>
  w d <workspace-name>
  w delete <workspace-name>

Commands:
  c, create   Create a new jj workspace using workspace-templates/<project>.sh
  d, delete   Delete a workspace folder, forget the jj workspace, and try to kill its tmux session

Legacy mode:
  w <project> [--no-tmux] <workspace-name>
    Treated the same as: w c <project> [--no-tmux] <workspace-name>
EOF
}

if ! command -v jj >/dev/null 2>&1; then
  echo "Error: jj is not installed or not in PATH" >&2
  exit 1
fi

templates_dir="${XDG_DATA_HOME:-$HOME/.local/share}/workspace-templates"

load_template() {
  local template_path="$1"

  unset w_source_repo w_destination_prefix w_tmux_project w_env_source w_base_ports
  unset -f w_extra_env_lines 2>/dev/null || true
  unset -f w_post_create 2>/dev/null || true

  # shellcheck disable=SC1090
  source "$template_path"

  if [[ -z "${w_source_repo:-}" ]]; then
    echo "Error: template must define w_source_repo: $template_path" >&2
    exit 1
  fi

  if [[ -z "${w_destination_prefix:-}" ]]; then
    echo "Error: template must define w_destination_prefix: $template_path" >&2
    exit 1
  fi

}

port_in_use() {
  local port="$1"
  lsof -nP -iTCP:"$port" -sTCP:LISTEN >/dev/null 2>&1
}

session_name_for_path() {
  basename "$1" | sed 's/[^A-Za-z0-9._-]/_/g'
}

workspace_exists_in_repo() {
  local repo="$1"
  local workspace_name="$2"
  jj -R "$repo" workspace list | grep -q "^${workspace_name}:"
}

resolve_workspace_name_for_template() {
  local requested_name="$1"

  if workspace_exists_in_repo "$w_source_repo" "$requested_name"; then
    printf '%s\n' "$requested_name"
    return 0
  fi

  local prefix_basename
  prefix_basename="$(basename "$w_destination_prefix")"
  if [[ -n "$prefix_basename" && "$requested_name" == "$prefix_basename"* ]]; then
    printf '%s\n' "$requested_name"
    return 0
  fi

  printf '%s%s\n' "$prefix_basename" "$requested_name"
}

create_workspace() {
  local project="$1"
  shift

  local run_tmux=true
  local workspace_name=""

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --no-tmux)
        run_tmux=false
        ;;
      -h|--help)
        usage
        exit 0
        ;;
      --*)
        echo "Error: unknown option: $1" >&2
        usage
        exit 1
        ;;
      *)
        if [[ -n "$workspace_name" ]]; then
          echo "Error: only one workspace name is allowed" >&2
          usage
          exit 1
        fi
        workspace_name="$1"
        ;;
    esac
    shift
  done

  if [[ -z "$workspace_name" ]]; then
    usage
    exit 1
  fi

  local template_path="$templates_dir/$project.sh"
  if [[ ! -f "$template_path" ]]; then
    echo "Error: workspace template not found: $template_path" >&2
    exit 1
  fi

  load_template "$template_path"

  local destination="${w_destination_prefix}${workspace_name}"
  w_tmux_project="${w_tmux_project:-$project}"
  w_env_source="${w_env_source:-.env}"

  if [[ ! -d "$w_source_repo" ]]; then
    echo "Error: source repository not found: $w_source_repo" >&2
    exit 1
  fi

  if [[ ! -d "$w_source_repo/.jj" ]]; then
    echo "Error: source repository is not a jj repo: $w_source_repo" >&2
    exit 1
  fi

  if [[ -e "$destination" ]]; then
    echo "Error: destination already exists: $destination" >&2
    exit 1
  fi

  if [[ ! -f "$w_source_repo/$w_env_source" ]]; then
    echo "Error: missing env source in repository: $w_source_repo/$w_env_source" >&2
    exit 1
  fi

  local port=""
  if declare -p w_base_ports >/dev/null 2>&1 && [[ ${#w_base_ports[@]} -gt 0 ]]; then
    local candidate_port
    for candidate_port in "${w_base_ports[@]}"; do
      if port_in_use "$candidate_port"; then
        continue
      fi

      port="$candidate_port"
      break
    done

    if [[ -z "$port" ]]; then
      echo "Error: no available PORT found from base ports: ${w_base_ports[*]}" >&2
      exit 1
    fi
  fi

  jj -R "$w_source_repo" workspace add "$destination"
  cp "$w_source_repo/$w_env_source" "$destination/.env"

  echo "Created workspace: $destination"
  echo "Copied .env"

  if [[ -n "$port" ]]; then
    local env_port_lines=("PORT=$port")
    if declare -f w_extra_env_lines >/dev/null 2>&1; then
      while IFS= read -r line; do
        env_port_lines+=("$line")
      done < <(w_extra_env_lines "$port")
    fi

    {
      local line
      for line in "${env_port_lines[@]}"; do
        printf '%s\n' "$line"
      done
    } > "$destination/.env.ports"

    echo "Wrote .env.ports"
  fi

  if declare -f w_post_create >/dev/null 2>&1; then
    (
      cd "$destination"
      w_post_create
    )
    echo "Ran project post-create setup"
  fi

  if [[ "$run_tmux" == true ]]; then
    if ! command -v tp >/dev/null 2>&1; then
      echo "Error: tmux is enabled but tp is not in PATH" >&2
      exit 1
    fi

    (cd "$destination" && tp "$w_tmux_project")
  fi
}

find_workspace_match() {
  local requested_name="$1"

  local matches=()
  local resolved_names=()
  local template_path
  shopt -s nullglob
  for template_path in "$templates_dir"/*.sh; do
    load_template "$template_path"

    local resolved_name
    resolved_name="$(resolve_workspace_name_for_template "$requested_name")"
    local destination="${w_destination_prefix}${resolved_name#$(basename "$w_destination_prefix")}"

    if [[ -d "$destination" ]] || workspace_exists_in_repo "$w_source_repo" "$resolved_name"; then
      matches+=("$template_path")
      resolved_names+=("$resolved_name")
    fi
  done
  shopt -u nullglob

  if [[ ${#matches[@]} -eq 0 ]]; then
    echo "Error: could not find workspace '$requested_name' in any configured template" >&2
    exit 1
  fi

  if [[ ${#matches[@]} -gt 1 ]]; then
    echo "Error: workspace '$requested_name' matched multiple templates:" >&2
    printf '  %s\n' "${matches[@]}" >&2
    exit 1
  fi

  printf '%s\t%s\n' "${matches[0]}" "${resolved_names[0]}"
}

delete_workspace() {
  local requested_name="$1"
  local match
  match="$(find_workspace_match "$requested_name")"
  local template_path="${match%%$'\t'*}"
  local workspace_name="${match#*$'\t'}"
  load_template "$template_path"

  local prefix_basename
  prefix_basename="$(basename "$w_destination_prefix")"
  local workspace_suffix="${workspace_name#${prefix_basename}}"
  local destination="${w_destination_prefix}${workspace_suffix}"
  local session_name
  session_name="$(session_name_for_path "$destination")"

  if workspace_exists_in_repo "$w_source_repo" "$workspace_name"; then
    jj -R "$w_source_repo" workspace forget "$workspace_name"
    echo "Forgot jj workspace: $workspace_name"
  else
    echo "JJ workspace already absent: $workspace_name"
  fi

  if [[ -e "$destination" ]]; then
    rm -rf "$destination"
    echo "Deleted folder: $destination"
  else
    echo "Folder already absent: $destination"
  fi

  if command -v tmux >/dev/null 2>&1; then
    if tmux has-session -t "$session_name" 2>/dev/null; then
      tmux kill-session -t "$session_name" >/dev/null 2>&1 || true
      echo "Killed tmux session: $session_name"
    else
      echo "Tmux session not found: $session_name"
    fi
  else
    echo "tmux not installed; skipped tmux session cleanup"
  fi
}

if [[ $# -eq 0 ]]; then
  usage
  exit 1
fi

case "$1" in
  c|create)
    shift
    if [[ $# -lt 2 ]]; then
      usage
      exit 1
    fi
    create_workspace "$@"
    ;;
  d|delete)
    shift
    if [[ $# -ne 1 ]]; then
      usage
      exit 1
    fi
    delete_workspace "$1"
    ;;
  -h|--help)
    usage
    ;;
  *)
    if [[ $# -lt 2 ]]; then
      usage
      exit 1
    fi
    create_workspace "$@"
    ;;
esac
