{{ if has "dev" ((index .chezmoi "tags") | default (list)) }}#!/usr/bin/env bash
set -euo pipefail

case "{{ .chezmoi.os }}" in
  darwin)
    if command -v brew >/dev/null 2>&1; then
      brew install go terraform
    fi
    ;;
  linux)
    if command -v apt-get >/dev/null 2>&1; then
      sudo apt-get update
      sudo apt-get install -y golang
    fi
    ;;
esac
{{ end }}